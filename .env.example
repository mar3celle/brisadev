# ══════════════════════════════════════════
#  BrisaDev — Variáveis de Ambiente
#  cp .env.example .env  e preenche abaixo
# ══════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────
# Obtém em: https://supabase.com/dashboard → project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...        # chave pública (safe)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... # SECRETA — nunca expõe!

# ── Stripe ─────────────────────────────────────────────────
# Obtém em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Price IDs — cria os produtos em: https://dashboard.stripe.com/products
# Copia os IDs também para index.html → STRIPE_PLANS
STRIPE_PRICE_STARTER=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ECOMMERCE=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Admin ──────────────────────────────────────────────────
# Segredo para assinar os tokens de sessão admin (mínimo 32 caracteres)
JWT_SECRET=coloca-aqui-uma-string-longa-e-aleatoria-minimo-32-chars

# ── Servidor ───────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3000

# ── Email (opcional — confirmações automáticas) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=brisadev@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx   # Gmail App Password
